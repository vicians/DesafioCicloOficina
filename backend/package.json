{
  "name": "omniconnect-backend",
  "version": "1.0.0",
  "description": "API Backend para o sistema OmniConnect",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/backend/src/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "db:migrate": "ts-node src/database/migrations/migrations.ts",
    "db:seed": "ts-node src/database/seeds/seeds.ts"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "firebase-admin": "^13.8.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "ngrok": "^5.0.0-beta.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
