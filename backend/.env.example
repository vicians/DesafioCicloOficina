# Servidor
NODE_ENV=development
PORT=3000
URL=http://localhost
BASE_URL=http://localhost
API_PORT=:3000

# Banco de dados
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Autenticação
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=1d

# Firebase
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# AI Service
AI_SERVICE_URL=http://localhost:3001

# WhatsApp (Meta API)
WA_ACCESS_TOKEN=your_whatsapp_access_token
WA_PHONE_NUMBER_ID=your_phone_number_id
VERIFY_TOKEN=your_webhook_verify_token

# Seeds - Usuário Admin
ADMIN_NOME=Nome do Admin
ADMIN_EMAIL=admin@example.com
ADMIN_CPF=00000000000
ADMIN_TELEFONE=11900000000
ADMIN_SENHA=senha_admin

# Seeds - Mecânico
MECANICO_NOME=Nome do Mecânico
MECANICO_EMAIL=mecanico@example.com
MECANICO_CPF=11111111111
MECANICO_TELEFONE=11911111111
MECANICO_SENHA=senha_mecanico

# Seeds - Cliente
CLIENTE_NOME=Nome do Cliente
CLIENTE_EMAIL=cliente@example.com
CLIENTE_CPF=22222222222
CLIENTE_TELEFONE=11922222222
CLIENTE_SENHA=senha_cliente
