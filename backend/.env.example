# ── DATABASE ──────────────────────────────────────────
DATABASE_URL='postgresql://usuario:senha@endereco:porta/nome_db'

# ── API & SECURITY ────────────────────────────────────
API_PORT=3000
BASE_URL="http://localhost:"
JWT_SECRET="chave_jwt"
JWT_EXPIRATION="30d"
INTERNAL_AUTH_TOKEN='token'

# ── WHATSAPP / META API ───────────────────────────────
VERIFY_TOKEN="token"
WA_PHONE_NUMBER_ID="number"
WA_BUSINESS_ACCOUNT_ID="number"
WA_ACCESS_TOKEN="token"

# ── SERVICES INTEGRATION ──────────────────────────────
AI_SERVICE_URL="http://localhost:3001"
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"

# ── SEEDING CREDENTIALS (DEVELOPMENT ONLY) ────────────
# Todos os campos abaixo são obrigatórios.
# O seed falha imediatamente se qualquer variável estiver ausente.

