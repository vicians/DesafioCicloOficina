NVIDIA_API_KEY='chave'
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

AI_MODEL=nvidia/nemotron-3-super-120b-a12b # Você que escolhe
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-1b-v2 # Você que escolhe
RAG_SPLITTING_STRATEGY='default' # Opções alternativas: largeContext & granular
SYSTEM_PROMPT='Prompt base do agente' # Use \n para quebra de linha, evite usar "Enter" aqui

PORT=3001
NODE_ENV=development

DATABASE_URL='postgresql://usuario:senha@endereco:porta/nome_db'

INTERNAL_AUTH_TOKEN='token'